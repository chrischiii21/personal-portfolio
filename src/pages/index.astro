				</div>
				<p class="text-xl text-[#103a62] font-medium mb-6">
					Software Engineer \ Full Stack Developer \ Tech Mentor
				</p>

				<!-- CTA Buttons -->
				<div
					class="flex flex-wrap items-center justify-center gap-3 mb-6"
				>
					<a
						href="mailto:alex@example.com"
						class="bg-[#103a62] text-white px-6 py-2.5 rounded-lg font-medium hover:bg-[#103a62]/90 transition-colors cursor-pointer shadow-md"
