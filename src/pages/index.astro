---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{profile.name} - Front-end Web Developer</title>
		<meta
			name="description"
			content="Front-end developer and UI/UX designer specializing in high-performance web applications with Astro, React, and Tailwind CSS."
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-[#0d1117] text-[#c9d1d9] font-sans antialiased">
		<div class="min-h-screen max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
			<div class="grid lg:grid-cols-[320px_1fr] gap-6">
				<ProfileSidebar {...profile} />
				<div class="space-y-6">
					<MainContent {...content} />
					<ProjectsSection projects={projects} />
					<ExperienceSection experiences={experiences} />
					<GallerySection items={gallery} />
				</div>
			</div>
		</div>

		<style>
			* {
				font-family: "Inter", sans-serif;
			}
		</style>
	</body>
</html>
