							>
						</div>
						<div class="space-y-6">
							<div>
								<h3
									class="text-sm font-semibold text-[#56a2e8] uppercase tracking-wide mb-3"
								>
									Frontend
								</h3><div class="flex flex-wrap gap-2">
									<span
										class="bg-white border border-[#93bfe9]/50 px-4 py-2 rounded-lg text-sm text-[#103a62] font-medium"
										>JavaScript</span
									><span
										class="bg-white border border-[#93bfe9]/50 px-4 py-2 rounded-lg text-sm text-[#103a62] font-medium"
										>TypeScript</span
									><span
										class="bg-white border border-[#93bfe9]/50 px-4 py-2 rounded-lg text-sm text-[#103a62] font-medium"
										>React</span
									><span
										class="bg-white border border-[#93bfe9]/50 px-4 py-2 rounded-lg text-sm text-[#103a62] font-medium"
										>Astro</span
									><span
										class="bg-white border border-[#93bfe9]/50 px-4 py-2 rounded-lg text-sm text-[#103a62] font-medium"
										>Tailwind CSS</span
									><span
										class="bg-white border border-[#93bfe9]/50 px-4 py-2 rounded-lg text-sm text-[#103a62] font-medium"
										>Vite</span
									>
								</div>
							</div>
							<div>
								<h3
									class="text-sm font-semibold text-[#56a2e8] uppercase tracking-wide mb-3"
								>
									Tools & Runtime
								</h3><div class="flex flex-wrap gap-2">
									<span
										class="bg-white border border-[#93bfe9]/50 px-4 py-2 rounded-lg text-sm text-[#103a62] font-medium"
										>Bun</span
									><span
										class="bg-white border border-[#93bfe9]/50 px-4 py-2 rounded-lg text-sm text-[#103a62] font-medium"
