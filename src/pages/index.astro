---
import "../styles/global.css";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Christy Montejo - Front-end Web Developer</title>
		<meta
			name="description"
			content="Front-end developer and UI/UX designer specializing in high-performance web applications with Astro, React, and Tailwind CSS."
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-[#f5f8fb] text-[#05080b] font-sans antialiased">
		<div class="min-h-screen max-w-4xl mx-auto px-6 py-12 md:py-16">
			<!-- Profile Header -->
			<header class="text-center mb-12">
				<div
					class="w-32 h-32 mx-auto mb-6 rounded-full bg-linear-to-br from-[#103a62] to-[#56a2e8] flex items-center justify-center text-6xl shadow-lg"
				>
					👨‍💻
				</div>
				<h1 class="text-4xl md:text-5xl font-bold text-[#05080b] mb-2">
					Christy Montejo
				</h1>
				<div class="flex items-center justify-center gap-2 mb-3">
					<span class="w-2 h-2 bg-[#56a2e8] rounded-full"></span>
					<p class="text-[#103a62]/70">Cebu City, Philippines</p>
				</div>
				<p class="text-xl text-[#103a62] font-medium mb-6">
					Front-end Web Developer \ UI/UX Designer \ Student Leader
				</p>

				<!-- CTA Buttons -->
				<div
					class="flex flex-wrap items-center justify-center gap-3 mb-6"
				>
					<a
						href="mailto:christy@example.com"
						class="bg-[#103a62] text-white px-6 py-2.5 rounded-lg font-medium hover:bg-[#103a62]/90 transition-colors cursor-pointer shadow-md"
					>
						Send Email
					</a>
					<a
						href="https://calendly.com"
						target="_blank"
						class="bg-white border-2 border-[#93bfe9] text-[#103a62] px-6 py-2.5 rounded-lg font-medium hover:bg-[#93bfe9]/10 transition-colors cursor-pointer"
					>
						Schedule a Call
					</a>
					<a
						href="/resume.pdf"
						download
						class="bg-white border-2 border-[#93bfe9] text-[#103a62] px-6 py-2.5 rounded-lg font-medium hover:bg-[#93bfe9]/10 transition-colors cursor-pointer"
					>
						Download Resume
					</a>
				</div>

				<!-- Achievement Badge -->
				<div
					class="inline-block bg-yellow-400/20 border border-yellow-500/40 rounded-lg px-4 py-2"
				>
					<p class="text-sm text-[#103a62] font-medium">
						� Class of 2026 / Astro Developer
					</p>
				</div>
			</header>

			<!-- Main Content -->
			<main class="space-y-16">
				<!-- About -->
				<section>
					<h2 class="text-3xl font-bold text-[#05080b] mb-6">
						About
					</h2>
					<div
						class="space-y-4 text-[#103a62]/90 leading-relaxed text-lg"
					>
						<p>
							I'm a front-end developer and UI/UX designer
							specializing in high-performance web applications
							built with <strong class="text-[#05080b]"
								>Astro</strong
							>, <strong class="text-[#05080b]">React</strong>,
							and <strong class="text-[#05080b]"
								>Tailwind CSS</strong
							>. I focus on "sales-first" design
							philosophies—creating digital experiences for
							trade-specific industries that prioritize lead
							generation and conversion optimization.
						</p>
						<p>
							Beyond code, I am deeply involved in student
							leadership, currently serving as a member of the
							Finance Committee and the Graduating Council for the
							Class of 2026. I bridge the gap between aesthetic
							design and functional, ROI-driven development.
						</p>
					</div>
				</section>

				<!-- Tech Stack & Experience - 2 Column Layout -->
				<section class="grid lg:grid-cols-[1.3fr_1fr] gap-12">
					<!-- Tech Stack Column -->
					<div>
						<div class="flex items-center justify-between mb-6">
