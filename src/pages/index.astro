---
import "../styles/global.css";
import ProfileHeader from "../components/ProfileHeader.astro";
import About from "../components/About.astro";
import TechStack from "../components/TechStack.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import Certifications from "../components/Certifications.astro";
import Gallery from "../components/Gallery.astro";
import SocialLinks from "../components/SocialLinks.astro";
import Speaking from "../components/Speaking.astro";
import Footer from "../components/Footer.astro";

// Profile Data
const profile = {
	name: "Christy Montejo",
	location: "Cebu City, Philippines",
	title: "Front-end Web Developer \\ UI/UX Designer \\ Student Leader",
	badge: "🎓 Class of 2026 / Astro Developer",
	email: "christy@example.com",
};

// About Bio
const bio = [
	`I'm a front-end developer and UI/UX designer specializing in high-performance web applications built with <strong class="text-[#05080b]">Astro</strong>, <strong class="text-[#05080b]">React</strong>, and <strong class="text-[#05080b]">Tailwind CSS</strong>. I focus on "sales-first" design philosophies—creating digital experiences for trade-specific industries that prioritize lead generation and conversion optimization.`,
	`Beyond code, I am deeply involved in student leadership, currently serving as a member of the Finance Committee and the Graduating Council for the Class of 2026. I bridge the gap between aesthetic design and functional, ROI-driven development.`,
];

// Tech Stack
const techStack = [
	{
		name: "Frontend",
		items: [
			"JavaScript",
			"TypeScript",
			"React",
			"Astro",
			"Tailwind CSS",
			"Vite",
		],
	},
	{
		name: "Tools & Runtime",
		items: ["Bun", "Node.js", "Git", "GitHub"],
	},
	{
		name: "Design & Strategy",
		items: ["UI/UX Design", "CRO", "Sales-First Layouts"],
	},
];

// Experience
const experiences = [
	{
		title: "OJT / Teaching Intern",
		company: "[Insert Institution Name]",
		period: "2026 – Present",
	},
	{
		title: "Finance Committee Member",
		company: "Graduating Council 2026",
		period: "2025 – 2026",
	},
	{
		title: "Part-time Web Developer",
		company: "Freelance / Project-Based",
		period: "2025 – Present",
	},
	{
		title: "B.S. Information Technology",
		company: "[Insert University Name]",
		period: "2022 – 2026",
	},
];

// Projects
const projects = [
	{
		title: "BuildPro (SkillGrid)",
		description:
			"A digital marketing platform and template repository for trade contractors (HVAC, Plumbing)",
		url: "https://buildpro.dev",
		domain: "buildpro.dev",
	},
	{
		title: "Argao Convergence 2025",
		description:
			'Design and organization for the "Youth Leading the Change" summit, including all visual branding',
		url: "https://argao2025.com",
		domain: "argao2025.com",
	},
	{
		title: "Graduation Logistics System",
		description:
			"Automated tracker for fee collections and pictorial schedules to streamline council operations",
		url: "https://grad-tracker.app",
		domain: "grad-tracker.app",
	},
];

// Certifications
const certifications = [
	{
		title: "Event Organizer",
		issuer: "Argao Convergence 2025",
	},
	{
		title: "Finance Committee Representative",
		issuer: "Graduating Council",
	},
	{
		title: "Astro Framework Proficiency",
		issuer: "Frontend Development",
	},
];

// Gallery
const gallery = [
	{
		label: "BuildPro Desktop",
		gradient: "bg-linear-to-br from-[#103a62] to-[#56a2e8]",
	},
	{
		label: "BuildPro Mobile",
		gradient: "bg-linear-to-br from-[#56a2e8] to-[#93bfe9]",
	},
	{
		label: "Argao Branding",
		gradient: "bg-linear-to-br from-[#93bfe9] to-[#56a2e8]",
	},
	{
		label: "Code Snippet",
		gradient: "bg-linear-to-br from-[#56a2e8] to-[#103a62]",
	},
	{
		label: "Git Workflow",
		gradient: "bg-linear-to-br from-[#103a62] to-[#93bfe9]",
	},
	{
		label: "UI Components",
		gradient: "bg-linear-to-br from-[#93bfe9] to-[#103a62]",
	},
	{
		label: "Design System",
		gradient: "bg-linear-to-br from-[#56a2e8] to-[#93bfe9]",
	},
	{
		label: "Astro Project",
		gradient: "bg-linear-to-br from-[#103a62] to-[#56a2e8]",
	},
];

// Social Links
const socialLinks = [
	{ name: "LinkedIn", url: "https://linkedin.com" },
	{ name: "GitHub", url: "https://github.com" },
	{ name: "Twitter", url: "https://twitter.com" },
];

// Speaking
const speaking = {
	description:
		"Available for speaking at events about software development, cloud architecture, and emerging technologies.",
	email: profile.email,
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{profile.name} - Front-end Web Developer</title>
		<meta
			name="description"
			content="Front-end developer and UI/UX designer specializing in high-performance web applications with Astro, React, and Tailwind CSS."
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-[#f5f8fb] text-[#05080b] font-sans antialiased">
		<div class="min-h-screen max-w-4xl mx-auto px-6 py-12 md:py-16">
			<ProfileHeader {...profile} />

			<main class="space-y-16">
				<About bio={bio} />

				<section class="grid lg:grid-cols-[1.3fr_1fr] gap-12">
					<TechStack categories={techStack} />
					<Experience experiences={experiences} />
				</section>

				<Projects projects={projects} />

				<Certifications certifications={certifications} />

				<Gallery items={gallery} />

				<SocialLinks links={socialLinks} />

				<Speaking {...speaking} />
			</main>

			<Footer
				name={profile.name}
				email={profile.email}
				socialLinks={socialLinks}
			/>
		</div>

		<style>
			* {
				font-family: "Inter", sans-serif;
			}
		</style>
	</body>
</html>
