							<div class="space-y-8">
								<div class="relative pl-8">
									<div
										class="absolute left-0 top-1 w-4 h-4 bg-[#56a2e8] rounded-full border-4 border-[#f5f8fb]"
									>
									</div><h3
										class="text-xl font-bold text-[#05080b]"
									>
										OJT / Teaching Intern
									</h3><p
										class="text-[#103a62] font-medium mb-1"
									>
										[Insert Institution Name]
									</p><p class="text-sm text-[#103a62]/70">
										2026 – Present
