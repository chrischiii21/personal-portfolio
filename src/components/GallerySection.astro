---
const { items } = Astro.props;
---

<div class="bg-[#0d1117] border border-[#30363d] rounded-lg p-6">
    <h3
        class="text-lg font-semibold text-[#e6edf3] mb-4 flex items-center gap-2"
    >
        <span>🖼️</span> Gallery
    </h3>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {
            items.map(
                (item: { label: string; gradient: string; image?: string }) => (
                    <div
                        class={`aspect-square ${item.gradient} rounded-lg overflow-hidden hover:scale-105 transition-transform cursor-pointer flex items-center justify-center border border-[#30363d]`}
                    >
                        {item.image ? (
                            <img
                                src={item.image}
                                alt={item.label}
                                class="w-full h-full object-cover"
                            />
                        ) : (
                            <div class="text-white text-center p-4">
                                <p class="text-xs font-medium">{item.label}</p>
                            </div>
                        )}
                    </div>
                ),
            )
        }
    </div>
</div>
