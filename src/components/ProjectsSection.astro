---
const { projects } = Astro.props;
---

<div class="bg-[#0d1117] border border-[#30363d] rounded-lg p-6">
    <h3
        class="text-lg font-semibold text-[#e6edf3] mb-4 flex items-center gap-2"
    >
        <span>🚀</span> Featured Projects
    </h3>
    <div class="space-y-4">
        {
            projects.map(
                (project: {
                    title: string;
                    description: string;
                    url: string;
                    tech: string[];
                }) => (
                    <a
                        href={project.url}
                        target="_blank"
                        class="block bg-[#161b22] border border-[#30363d] rounded-lg p-4 hover:border-[#58a6ff] transition-colors group"
                    >
                        <div class="flex items-start justify-between mb-2">
                            <h4 class="text-[#58a6ff] font-semibold group-hover:underline">
                                {project.title}
                            </h4>
                            <svg
                                class="w-4 h-4 text-[#7d8590] group-hover:text-[#58a6ff]"
                                fill="currentColor"
                                viewBox="0 0 16 16"
                            >
                                <path d="M3.75 2h3.5a.75.75 0 0 1 0 1.5h-3.5a.25.25 0 0 0-.25.25v8.5c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25v-3.5a.75.75 0 0 1 1.5 0v3.5A1.75 1.75 0 0 1 12.25 14h-8.5A1.75 1.75 0 0 1 2 12.25v-8.5C2 2.784 2.784 2 3.75 2Zm6.854-1h4.146a.25.25 0 0 1 .25.25v4.146a.25.25 0 0 1-.427.177L13.03 4.03 9.28 7.78a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042l3.75-3.75-1.543-1.543A.25.25 0 0 1 10.604 1Z" />
                            </svg>
                        </div>
                        <p class="text-[#c9d1d9] text-sm mb-3">
                            {project.description}
                        </p>
                        <div class="flex flex-wrap gap-2">
                            {project.tech.map((t: string) => (
                                <span class="text-xs text-[#7d8590] bg-[#0d1117] px-2 py-0.5 rounded-full">
                                    {t}
                                </span>
                            ))}
                        </div>
                    </a>
                ),
            )
        }
    </div>
</div>
